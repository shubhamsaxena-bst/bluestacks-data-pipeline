{
  "name": "LS_BSI_Databricks",
  "properties": {
    "type": "AzureDatabricks",
    "typeProperties": {
      "domain": "https://adb-xxxxxxxxxxxxxxx.azuredatabricks.net",
      "accessToken": {
        "type": "AzureKeyVaultSecret",
        "store": { "referenceName": "LS_BSI_KeyVault", "type": "LinkedServiceReference" },
        "secretName": "databricks-token"
      },
      "newClusterVersion": "14.3.x-scala2.12",
      "newClusterNodeType": "Standard_DS4_v2",
      "newClusterNumOfWorker": "2:8",
      "newClusterSparkConf": {
        "spark.databricks.delta.optimizeWrite.enabled": "true",
        "spark.databricks.delta.autoCompact.enabled": "true"
      }
    }
  }
}

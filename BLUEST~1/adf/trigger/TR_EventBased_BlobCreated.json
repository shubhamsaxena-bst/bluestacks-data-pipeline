{
  "name": "TR_EventGrid_RawBlobCreated",
  "properties": {
    "type": "BlobEventsTrigger",
    "typeProperties": {
      "blobPathBeginsWith": "/raw/blobs/email_campaign_engagement/",
      "ignoreEmptyBlobs": true,
      "scope": "/subscriptions/xxxx/resourceGroups/bsi-prod-rg/providers/Microsoft.Storage/storageAccounts/bsimktadls",
      "events": ["Microsoft.Storage.BlobCreated"]
    },
    "pipelines": [
      { "pipelineReference": { "referenceName": "PL_Ingest_ParamSource", "type": "PipelineReference" },
        "parameters": { "sourceName": "email_campaign_engagement", "fileFormat": "csv", "ingestDate": "@formatDateTime(utcnow(), 'yyyy-MM-dd')" } }
    ]
  },
  "description": "Near-real-time trigger for email open/click/unsubscribe engagement events, complementing the daily batch schedule so lifecycle marketing can react same-day rather than waiting for the next scheduled run."
}

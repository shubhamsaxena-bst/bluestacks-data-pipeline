{
  "name": "DS_Generic_Landing_Blob",
  "properties": {
    "linkedServiceName": { "referenceName": "LS_BSI_ADLSGen2", "type": "LinkedServiceReference" },
    "parameters": {
      "sourceName": { "type": "string" },
      "fileFormat": { "type": "string", "defaultValue": "json" },
      "ingestDate": { "type": "string" }
    },
    "type": "Json",
    "typeProperties": {
      "location": {
        "type": "AzureBlobFSLocation",
        "fileSystem": "raw",
        "folderPath": {
          "value": "@concat(dataset().sourceName, '/dt=', dataset().ingestDate)",
          "type": "Expression"
        }
      }
    }
  },
  "description": "Single reusable/parameterized dataset for every raw source - avoids one dataset per feed."
}
